<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.woongjin.survey.domain.member.repository.MemberMapper">

    <resultMap id="MemberResultMap" type="com.woongjin.survey.domain.member.entity.Member">
        <id     property="memberId"  column="member_id"/>
        <result property="loginId"   column="login_id"/>
        <result property="password"  column="password"/>
        <result property="name"      column="name"/>
        <result property="email"     column="email"/>
        <result property="role"      column="role"/>
        <result property="status"    column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 로그인 ID로 회원 조회 -->
    <select id="findByLoginId" parameterType="string" resultMap="MemberResultMap">
        SELECT member_id, login_id, password, name, email, role, status, created_at, updated_at
        FROM member
        WHERE login_id = #{loginId}
          AND status = 'ACTIVE'
    </select>

    <!-- 회원 PK로 조회 (토큰 재발급 시 사용) -->
    <select id="findById" parameterType="long" resultMap="MemberResultMap">
        SELECT member_id, login_id, password, name, email, role, status, created_at, updated_at
        FROM member
        WHERE member_id = #{memberId}
          AND status = 'ACTIVE'
    </select>

    <!-- 회원 등록 -->
    <insert id="insertMember" parameterType="com.woongjin.survey.domain.member.entity.Member"
            useGeneratedKeys="true" keyProperty="memberId">
        INSERT INTO member (login_id, password, name, email, role, status, created_at, updated_at)
        VALUES (#{loginId}, #{password}, #{name}, #{email}, #{role}, #{status}, NOW(), NOW())
    </insert>

</mapper>
